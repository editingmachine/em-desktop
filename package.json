{
  "name": "em-desktop",
  "version": "1.0.7",
  "description": "Editing Machine desktop shell — portal window + background file-sync daemon",
  "author": "Editing Machine",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev": "concurrently \"npm:dev:renderer\" \"cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "conf": "^10.2.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
